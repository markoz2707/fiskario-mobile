# Test Environment Configuration
NODE_ENV=test
ENVIRONMENT=test

# API Configuration (test backend)
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=15000

# Authentication (test keys)
AUTH_TOKEN_STORAGE_KEY=@fiskario_test_auth_token
AUTH_REFRESH_TOKEN_STORAGE_KEY=@fiskario_test_refresh_token

# e-Deklaracje Mobile Settings (test)
EDEKLARACJE_ENABLE_NOTIFICATIONS=true
EDEKLARACJE_AUTO_REFRESH_INTERVAL=60000
EDEKLARACJE_MAX_RETRY_ATTEMPTS=2

# Push Notifications (test)
PUSH_NOTIFICATION_ENABLED=true
PUSH_NOTIFICATION_API_KEY=test-push-key

# Analytics (disabled for test)
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=test-analytics-key

# Logging (verbose for testing)
LOG_LEVEL=debug
LOG_REMOTE_ENABLED=false

# Security (test settings)
BIOMETRIC_AUTH_ENABLED=false
PIN_CODE_ENABLED=false

# Feature Flags (all enabled for testing)
FEATURE_EDEKLARACJE=true
FEATURE_KSEF=true
FEATURE_ZUS=true
FEATURE_OCR=true

# UI Configuration
THEME=default
LANGUAGE=pl
CURRENCY=PLN
DATE_FORMAT=DD.MM.YYYY