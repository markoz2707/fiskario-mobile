# API Configuration
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=30000

# Environment
NODE_ENV=development
ENVIRONMENT=test

# Authentication
AUTH_TOKEN_STORAGE_KEY=@fiskario_auth_token
AUTH_REFRESH_TOKEN_STORAGE_KEY=@fiskario_refresh_token

# e-Deklaracje Mobile Settings
EDEKLARACJE_ENABLE_NOTIFICATIONS=true
EDEKLARACJE_AUTO_REFRESH_INTERVAL=300000
EDEKLARACJE_MAX_RETRY_ATTEMPTS=3

# Push Notifications
PUSH_NOTIFICATION_ENABLED=true
PUSH_NOTIFICATION_API_KEY=your-push-notification-key

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=your-analytics-key

# Logging
LOG_LEVEL=debug
LOG_REMOTE_ENABLED=false

# Security
BIOMETRIC_AUTH_ENABLED=true
PIN_CODE_ENABLED=true

# Feature Flags
FEATURE_EDEKLARACJE=true
FEATURE_KSEF=true
FEATURE_ZUS=true
FEATURE_OCR=true

# UI Configuration
THEME=default
LANGUAGE=pl
CURRENCY=PLN
DATE_FORMAT=DD.MM.YYYY